{
  "name": "ha-pi-agent",
  "version": "0.3.0",
  "description": "Pi agent Home Assistant add-on",
  "private": true,
  "packageManager": "pnpm@10.32.1",
  "type": "module",
  "scripts": {
    "build": "pnpm run build:server && pnpm run build:frontend",
    "build:server": "node esbuild.server.mjs",
    "build:frontend": "node esbuild.frontend.mjs",
    "clean": "rm -rf dist",
    "test": "vitest run",
    "test:watch": "vitest",
    "dev": "pnpm run build && node dist/server.js --provider anthropic --model claude-sonnet-4-5-20250929 --log-level debug",
    "typecheck": "tsc",
    "watch:server": "node esbuild.server.mjs --watch",
    "watch:frontend": "node esbuild.frontend.mjs --watch"
  },
  "dependencies": {
    "@mariozechner/pi-coding-agent": "^0.70.2",
    "express": "^4.21.2",
    "ws": "^8.18.2"
  },
  "devDependencies": {
    "@types/express": "^5.0.0",
    "@types/node": "^22.0.0",
    "@types/ws": "^8.5.14",
    "dompurify": "^3.2.6",
    "esbuild": "^0.27.7",
    "highlight.js": "^11.11.1",
    "marked": "^15.0.12",
    "typescript": "^5.8.3",
    "vitest": "^4.1.5"
  }
}
