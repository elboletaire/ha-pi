{
  "name": "pi-homeassistant",
  "version": "1.0.0",
  "description": "Home Assistant helper binary + skills for coding agents",
  "main": "dist/index.js",
  "bin": {
    "ha-helper": "dist/index.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "start": "tsx src/index.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:integration": "vitest run tests/integration"
  },
  "keywords": [
    "home-assistant",
    "cli",
    "agent",
    "pi-package"
  ],
  "author": "",
  "license": "ISC",
  "pi": {
    "skills": [
      "./skills/home-assistant"
    ]
  },
  "packageManager": "pnpm@10.32.1",
  "dependencies": {
    "home-assistant-js-websocket": "^9.6.0"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "vitest": "^4.1.2"
  }
}
